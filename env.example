PORT=3001

# Shopify App credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_themes,write_files
HOST=https://your-backend.onrender.com

# Groq AI
GROQ_API_KEY=your_groq_api_key

# PostgreSQL (Render internal URL)
DATABASE_URL=postgresql://user:password@host:5432/viralclip

# Frontend URL (Netlify)
FRONTEND_URL=https://your-app.netlify.app

# App
APP_SECRET=your_random_secret_string
